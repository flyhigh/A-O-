# Copy this file to `.env` and fill in values.

# Inbound auth for clients (e.g. Claude Code sends ANTHROPIC_AUTH_TOKEN as Authorization).
GATEWAY_TOKEN=local-dev-token

# Upstream OpenAI Responses endpoint.
UPSTREAM_RESPONSES_URL=https://api.openai.com/v1/responses

# Upstream API key (either env var works).
OPENAI_API_KEY=
# UPSTREAM_API_KEY=

# Optional: load upstream config from Codex CLI files (auth.json/config.toml).
# If UPSTREAM_RESPONSES_URL / OPENAI_API_KEY are set, they take priority.
# CODEX_AUTH_JSON_PATH=C:\Users\<you>\.codex\auth.json
# CODEX_CONFIG_TOML_PATH=C:\Users\<you>\.codex\config.toml

# Optional: forward reasoning effort to the upstream Responses API.
# Supports e.g. minimal/low/medium/high/xhigh (depending on your upstream).
# MODEL_REASONING_EFFORT=xhigh
# UPSTREAM_REASONING_FIELD=reasoning

# Optional: disable response storage on the upstream (sends store=false).
# DISABLE_RESPONSE_STORAGE=true

# Default model if the client request doesn't include `model`.
ANTHROPIC_MODEL=my-model
